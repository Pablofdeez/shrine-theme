{{ 'shrine-custom.css' | asset_url | stylesheet_tag }}

<style>
  .cmp-table-section {
    padding: 8rem 0;
    background: {{ section.settings.bg_color }};
  }
  .cmp-table-section__header {
    text-align: center;
    margin-bottom: 5rem;
  }
  .cmp-table-section__heading {
    font-family: var(--shrine-font-heading);
    font-size: clamp(2.8rem, 5vw, 4.8rem);
    color: {{ section.settings.heading_color }};
    margin-bottom: 1.2rem;
  }
  .cmp-table-section__heading em {
    color: {{ section.settings.heading_highlight }};
    font-style: normal;
  }
  .cmp-table-section__subtext {
    font-family: var(--shrine-font-body);
    font-size: 1.6rem;
    color: rgba(45,27,78,0.7);
    max-width: 52rem;
    margin: 0 auto;
  }
  .cmp-table-wrapper {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem;
    overflow-x: auto;
  }
  .cmp-table {
    width: 100%;
    border-collapse: collapse;
    border-radius: var(--shrine-radius-md);
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(45,27,78,0.1);
  }
  .cmp-table thead tr {
    background: var(--shrine-purple-deep);
  }
  .cmp-table thead th {
    padding: 2rem 2.4rem;
    font-family: var(--shrine-font-body);
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    text-align: center;
  }
  .cmp-table thead th:first-child {
    text-align: left;
    background: rgba(255,255,255,0.05);
  }
  .cmp-table thead th.cmp-table__our-col {
    background: var(--shrine-purple-mid);
  }
  .cmp-table tbody tr {
    border-bottom: 1px solid rgba(123,94,167,0.1);
    transition: background 0.2s;
  }
  .cmp-table tbody tr:last-child { border-bottom: none; }
  .cmp-table tbody tr:hover { background: rgba(240,232,255,0.4); }
  .cmp-table tbody tr:nth-child(even) { background: rgba(253,250,255,0.6); }
  .cmp-table td {
    padding: 1.6rem 2.4rem;
    font-family: var(--shrine-font-body);
    font-size: 1.4rem;
    color: var(--shrine-purple-deep);
    text-align: center;
    vertical-align: middle;
  }
  .cmp-table td:first-child {
    text-align: left;
    font-weight: 600;
    color: var(--shrine-purple-deep);
  }
  .cmp-table td.cmp-table__our-col {
    background: rgba(123,94,167,0.06);
    font-weight: 700;
  }
  .cmp-icon--yes  { color: #7B5EA7; font-size: 1.8rem; }
  .cmp-icon--no   { color: #ccc;    font-size: 1.8rem; }
  @media (max-width: 749px) {
    .cmp-table td, .cmp-table th { padding: 1.2rem 1.4rem; font-size: 1.2rem; }
  }
</style>

<section class="cmp-table-section shrine-reveal">
  <div class="cmp-table-section__header page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="cmp-table-section__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="cmp-table-section__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}
  </div>

  <div class="cmp-table-wrapper">
    <table class="cmp-table" role="table">
      <thead>
        <tr>
          <th scope="col">Característica</th>
          <th scope="col" class="cmp-table__our-col">{{ section.settings.our_brand_label }}</th>
          {%- for block in section.blocks -%}
            {%- if block.type == 'competitor' -%}
              <th scope="col">{{ block.settings.name }}</th>
            {%- endif -%}
          {%- endfor -%}
        </tr>
      </thead>
      <tbody>
        {%- for block in section.blocks -%}
          {%- if block.type == 'row' -%}
            <tr {{ block.shopify_attributes }}>
              <td>{{ block.settings.feature }}</td>
              <td class="cmp-table__our-col">
                {%- if block.settings.our_value == 'yes' -%}
                  <span class="cmp-icon--yes">✓</span>
                {%- elsif block.settings.our_value == 'no' -%}
                  <span class="cmp-icon--no">✗</span>
                {%- else -%}
                  {{ block.settings.our_value }}
                {%- endif -%}
              </td>
              {%- assign comp_vals = block.settings.competitor_values | split: ',' -%}
              {%- for val in comp_vals -%}
                {%- assign v = val | strip -%}
                <td>
                  {%- if v == 'yes' -%}<span class="cmp-icon--yes">✓</span>
                  {%- elsif v == 'no' -%}<span class="cmp-icon--no">✗</span>
                  {%- else -%}{{ v }}
                  {%- endif -%}
                </td>
              {%- endfor -%}
            </tr>
          {%- endif -%}
        {%- endfor -%}
      </tbody>
    </table>
  </div>
</section>

{% schema %}
{
  "name": "Tabla Comparativa",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header","footer"] },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "¿Por qué elegirnos?"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtexto",
      "default": "Comparamos nuestra calidad con la competencia."
    },
    {
      "type": "text",
      "id": "our_brand_label",
      "label": "Nombre de tu marca",
      "default": "Nuestra Marca"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#FDFAFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color del título",
      "default": "#2D1B4E"
    },
    {
      "type": "color",
      "id": "heading_highlight",
      "label": "Color resaltado del título",
      "default": "#7B5EA7"
    }
  ],
  "blocks": [
    {
      "type": "competitor",
      "name": "Competidor (columna)",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Nombre del competidor",
          "default": "Otras marcas"
        }
      ]
    },
    {
      "type": "row",
      "name": "Fila de comparación",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Característica",
          "default": "Material orgánico certificado"
        },
        {
          "type": "text",
          "id": "our_value",
          "label": "Nuestro valor (yes / no / texto)",
          "default": "yes",
          "info": "Escribe 'yes', 'no', o cualquier texto"
        },
        {
          "type": "text",
          "id": "competitor_values",
          "label": "Valores competidores (separados por coma)",
          "default": "no, no",
          "info": "Un valor por cada columna competidor, separados por coma. Ej: yes, no, Parcial"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tabla Comparativa",
      "blocks": [
        { "type": "competitor", "settings": { "name": "Marca A" } },
        { "type": "competitor", "settings": { "name": "Marca B" } },
        { "type": "row", "settings": { "feature": "Material orgánico certificado", "our_value": "yes", "competitor_values": "no, no" } },
        { "type": "row", "settings": { "feature": "Hipoalergénico", "our_value": "yes", "competitor_values": "no, Parcial" } },
        { "type": "row", "settings": { "feature": "Sin BPA", "our_value": "yes", "competitor_values": "yes, no" } },
        { "type": "row", "settings": { "feature": "Certificado OEKO-TEX", "our_value": "yes", "competitor_values": "no, no" } },
        { "type": "row", "settings": { "feature": "Devolución 30 días", "our_value": "yes", "competitor_values": "no, 14 días" } }
      ]
    }
  ]
}
{% endschema %}
